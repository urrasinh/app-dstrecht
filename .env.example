# Firebase config (Console → Project Settings → Your apps → Web App)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Apps Script Web App URL (deploy script in apps-script/Code.gs and paste exec URL here)
VITE_BACKEND_URL=

# Firebase Cloud Messaging — VAPID public key
# Console → Project Settings → Cloud Messaging → Web configuration → Generate key pair
VITE_FCM_VAPID_KEY=
